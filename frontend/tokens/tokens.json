{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "XIV Raid Planner design tokens. Three tiers: primitive (raw values) -> semantic (intent) -> component (per-component). Atoms are verbatim from frontend/src/index.css; structure reflects the redesign. Dark is the base theme; light values live in tokens.light.json as overrides of the SEMANTIC tier only.",

  "primitive": {
    "$description": "Tier 1 — raw values. Never referenced directly by components; only by the semantic tier. Renaming a brand color happens here once.",

    "color": {
      "teal": {
        "400": { "$type": "color", "$value": "#2dd4bf" },
        "500": { "$type": "color", "$value": "#14b8a6" },
        "600": { "$type": "color", "$value": "#0d9488" },
        "muted": { "$type": "color", "$value": "#0d7377" },
        "deep": { "$type": "color", "$value": "#0891b2" },
        "contrast": { "$type": "color", "$value": "#052e2b" }
      },
      "ink": {
        "0": { "$type": "color", "$value": "#050508", "$description": "darkest — app background" },
        "1": { "$type": "color", "$value": "#0a0a0f" },
        "2": { "$type": "color", "$value": "#0e0e14" },
        "3": { "$type": "color", "$value": "#121218" },
        "4": { "$type": "color", "$value": "#18181f" },
        "5": { "$type": "color", "$value": "#1e1e26", "$description": "lightest surface — interactive" }
      },
      "border": {
        "subtle": { "$type": "color", "$value": "#14141c" },
        "default": { "$type": "color", "$value": "#1f1f28" }
      },
      "grey": {
        "100": { "$type": "color", "$value": "#f0f0f5" },
        "300": { "$type": "color", "$value": "#a1a1aa" },
        "500": { "$type": "color", "$value": "#71717a" },
        "600": { "$type": "color", "$value": "#52525b" },
        "700": { "$type": "color", "$value": "#3f3f46" }
      },
      "role": {
        "tank": { "$type": "color", "$value": "#5a9fd4" },
        "healer": { "$type": "color", "$value": "#5ad490" },
        "melee": { "$type": "color", "$value": "#d45a5a" },
        "ranged": { "$type": "color", "$value": "#d4a05a" },
        "caster": { "$type": "color", "$value": "#b45ad4" }
      },
      "membership": {
        "owner": { "$type": "color", "$value": "#14b8a6" },
        "lead": { "$type": "color", "$value": "#a855f7" },
        "member": { "$type": "color", "$value": "#3b82f6" },
        "viewer": { "$type": "color", "$value": "#71717a" },
        "linked": { "$type": "color", "$value": "#f59e0b" }
      },
      "gear": {
        "raid": { "$type": "color", "$value": "#f87171" },
        "tome": { "$type": "color", "$value": "#2dd4bf" },
        "base-tome": { "$type": "color", "$value": "#60a5fa" },
        "augmented": { "$type": "color", "$value": "#fcd34d" },
        "crafted": { "$type": "color", "$value": "#fb923c" }
      },
      "material": {
        "twine": { "$type": "color", "$value": "#3b82f6", "$description": "armor upgrade" },
        "glaze": { "$type": "color", "$value": "#a855f7", "$description": "accessory upgrade" },
        "solvent": { "$type": "color", "$value": "#eab308", "$description": "weapon upgrade" },
        "tomestone": { "$type": "color", "$value": "#f97316", "$description": "universal" }
      },
      "signal": {
        "success": { "$type": "color", "$value": "#22c55e" },
        "warning": { "$type": "color", "$value": "#eab308" },
        "error": { "$type": "color", "$value": "#ef4444" },
        "info": { "$type": "color", "$value": "#3b82f6" }
      },
      "floor": {
        "1": { "$type": "color", "$value": "#22c55e", "$description": "M9S · accessories" },
        "2": { "$type": "color", "$value": "#3b82f6", "$description": "M10S · left side" },
        "3": { "$type": "color", "$value": "#a855f7", "$description": "M11S · body" },
        "4": { "$type": "color", "$value": "#f59e0b", "$description": "M12S · weapon" }
      }
    },

    "font": {
      "family": {
        "display": { "$type": "fontFamily", "$value": ["\"Exo 2\"", "\"Inter\"", "system-ui", "-apple-system", "BlinkMacSystemFont", "sans-serif"] },
        "sans": { "$type": "fontFamily", "$value": ["\"Inter\"", "system-ui", "-apple-system", "BlinkMacSystemFont", "sans-serif"] },
        "mono": { "$type": "fontFamily", "$value": ["\"JetBrains Mono\"", "ui-monospace", "SFMono-Regular", "monospace"] }
      },
      "weight": {
        "normal": { "$type": "fontWeight", "$value": 400 },
        "medium": { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 },
        "bold": { "$type": "fontWeight", "$value": 700 },
        "extrabold": { "$type": "fontWeight", "$value": 800 }
      },
      "size": {
        "hero": { "$type": "dimension", "$value": "30px" },
        "title": { "$type": "dimension", "$value": "24px" },
        "section": { "$type": "dimension", "$value": "20px" },
        "lg": { "$type": "dimension", "$value": "18px" },
        "body": { "$type": "dimension", "$value": "16px" },
        "sm": { "$type": "dimension", "$value": "14px" },
        "caption": { "$type": "dimension", "$value": "12px" },
        "micro": { "$type": "dimension", "$value": "11px", "$description": "uppercase section labels only; floor is 9px (lint: no-tiny-text)" }
      }
    },

    "space": {
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "6": { "$type": "dimension", "$value": "24px" },
      "8": { "$type": "dimension", "$value": "32px" },
      "12": { "$type": "dimension", "$value": "48px" }
    },

    "duration": {
      "fast":   { "$type": "duration", "$value": "150ms" },
      "normal": { "$type": "duration", "$value": "200ms" },
      "slow":   { "$type": "duration", "$value": "300ms" }
    },

    "easing": {
      "standard":    { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "decelerate":  { "$type": "cubicBezier", "$value": [0, 0, 0, 1] },
      "accelerate":  { "$type": "cubicBezier", "$value": [0.3, 0, 1, 1] }
    },

    "radius": {
      "sm": { "$type": "dimension", "$value": "6px" },
      "base": { "$type": "dimension", "$value": "8px" },
      "lg": { "$type": "dimension", "$value": "12px" },
      "xl": { "$type": "dimension", "$value": "16px" },
      "pill": { "$type": "dimension", "$value": "999px" }
    },

    "size": {
      "container": {
        "$description": "Width ceilings, re-derived for the left-rail layout (the old 'no sidebar / 160rem data' tier is retired). The rail (72px) is OUTSIDE these; these cap the content column.",
        "data": { "$type": "dimension", "$value": "2160px", "$description": "data-dense spine pages (Roster/Loot) on ultrawide" },
        "standard": { "$type": "dimension", "$value": "1760px", "$description": "Home / Schedule dashboards" },
        "focus": { "$type": "dimension", "$value": "1100px", "$description": "Player Hub, settings, forms" },
        "doc": { "$type": "dimension", "$value": "960px", "$description": "docs / reading width" }
      },
      "rail": { "$type": "dimension", "$value": "72px", "$description": "the global context rail (Person layer)" },
      "control": {
        "sm": { "$type": "dimension", "$value": "28px" },
        "base": { "$type": "dimension", "$value": "34px" },
        "lg": { "$type": "dimension", "$value": "40px" }
      }
    }
  },

  "semantic": {
    "$description": "Tier 2 — intent. THIS is what components and the app reference. Light theme overrides only this tier. 'Same color = same meaning' lives here.",

    "color": {
      "surface": {
        "base": { "$type": "color", "$value": "{primitive.color.ink.0}", "$description": "app background" },
        "raised": { "$type": "color", "$value": "{primitive.color.ink.1}", "$description": "rail, top bar" },
        "card": { "$type": "color", "$value": "{primitive.color.ink.2}" },
        "elevated": { "$type": "color", "$value": "{primitive.color.ink.3}", "$description": "popovers, elevated cards" },
        "overlay": { "$type": "color", "$value": "{primitive.color.ink.4}", "$description": "modals, menus" },
        "interactive": { "$type": "color", "$value": "{primitive.color.ink.5}", "$description": "inputs, hover targets" }
      },
      "accent": {
        "default": { "$type": "color", "$value": "{primitive.color.teal.500}", "$description": "the one primary action / active nav" },
        "hover": { "$type": "color", "$value": "{primitive.color.teal.400}" },
        "dim": { "$type": "color", "$value": "rgba(20, 184, 166, 0.15)", "$description": "active/selected backgrounds" },
        "muted": { "$type": "color", "$value": "{primitive.color.teal.muted}" },
        "deep": { "$type": "color", "$value": "{primitive.color.teal.deep}", "$description": "gradient end" },
        "on-accent": { "$type": "color", "$value": "{primitive.color.teal.contrast}", "$description": "text on accent fills" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{primitive.color.grey.100}", "$description": "15.2:1" },
        "secondary": { "$type": "color", "$value": "{primitive.color.grey.300}", "$description": "6.1:1" },
        "tertiary": { "$type": "color", "$value": "{primitive.color.grey.500}", "$description": "4.5:1 — labels, meta" },
        "muted": { "$type": "color", "$value": "{primitive.color.grey.600}" },
        "disabled": { "$type": "color", "$value": "{primitive.color.grey.700}" },
        "on-accent": { "$type": "color", "$value": "{primitive.color.teal.contrast}" }
      },
      "border": {
        "subtle": { "$type": "color", "$value": "{primitive.color.border.subtle}", "$description": "inner dividers" },
        "default": { "$type": "color", "$value": "{primitive.color.border.default}", "$description": "card edges" },
        "highlight": { "$type": "color", "$value": "{primitive.color.teal.500}", "$description": "active/selected edge" },
        "focus": { "$type": "color", "$value": "rgba(20, 184, 166, 0.5)" }
      },
      "interaction": {
        "focus-ring": { "$type": "color", "$value": "rgba(20, 184, 166, 0.4)" },
        "hover-overlay": { "$type": "color", "$value": "rgba(255, 255, 255, 0.05)" },
        "active-bg": { "$type": "color", "$value": "rgba(20, 184, 166, 0.15)" }
      },
      "role": {
        "tank": { "$type": "color", "$value": "{primitive.color.role.tank}" },
        "healer": { "$type": "color", "$value": "{primitive.color.role.healer}" },
        "melee": { "$type": "color", "$value": "{primitive.color.role.melee}" },
        "ranged": { "$type": "color", "$value": "{primitive.color.role.ranged}" },
        "caster": { "$type": "color", "$value": "{primitive.color.role.caster}" }
      },
      "gear-source": {
        "raid": { "$type": "color", "$value": "{primitive.color.gear.raid}" },
        "tome": { "$type": "color", "$value": "{primitive.color.gear.tome}" },
        "base-tome": { "$type": "color", "$value": "{primitive.color.gear.base-tome}" },
        "augmented": { "$type": "color", "$value": "{primitive.color.gear.augmented}" },
        "crafted": { "$type": "color", "$value": "{primitive.color.gear.crafted}" }
      },
      "membership": {
        "owner": { "$type": "color", "$value": "{primitive.color.membership.owner}" },
        "lead": { "$type": "color", "$value": "{primitive.color.membership.lead}" },
        "member": { "$type": "color", "$value": "{primitive.color.membership.member}" },
        "viewer": { "$type": "color", "$value": "{primitive.color.membership.viewer}" },
        "linked": { "$type": "color", "$value": "{primitive.color.membership.linked}" }
      },
      "status": {
        "success": { "$type": "color", "$value": "{primitive.color.signal.success}" },
        "warning": { "$type": "color", "$value": "{primitive.color.signal.warning}" },
        "error": { "$type": "color", "$value": "{primitive.color.signal.error}" },
        "info": { "$type": "color", "$value": "{primitive.color.signal.info}" }
      }
    },

    "motion": {
      "hover":         { "$type": "custom-motion", "$value": { "duration": "{primitive.duration.fast}",   "easing": "{primitive.easing.standard}" } },
      "popover-enter": { "$type": "custom-motion", "$value": { "duration": "{primitive.duration.normal}", "easing": "{primitive.easing.decelerate}" } },
      "toggle-slide":  { "$type": "custom-motion", "$value": { "duration": "{primitive.duration.normal}", "easing": "{primitive.easing.standard}" } },
      "tab-switch":    { "$type": "custom-motion", "$value": { "duration": "{primitive.duration.fast}",   "easing": "{primitive.easing.standard}" } }
    },

    "shadow": {
      "sm":   { "$type": "shadow", "$value": "0 1px 2px rgba(0, 0, 0, 0.3)" },
      "md":   { "$type": "shadow", "$value": "0 4px 6px rgba(0, 0, 0, 0.4)" },
      "lg":   { "$type": "shadow", "$value": "0 10px 15px rgba(0, 0, 0, 0.5)" },
      "xl":   { "$type": "shadow", "$value": "0 20px 25px rgba(0, 0, 0, 0.6)" },
      "glow": { "$type": "shadow", "$value": "0 0 20px rgba(20, 184, 166, 0.15)" }
    },

    "typography": {
      "$description": "Composite text styles — use these, not raw size+weight.",
      "hero": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.extrabold}", "fontSize": "{primitive.font.size.hero}", "letterSpacing": "-0.01em" } },
      "title": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.bold}", "fontSize": "{primitive.font.size.title}", "letterSpacing": "-0.01em" } },
      "section": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.bold}", "fontSize": "{primitive.font.size.section}" } },
      "body": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.normal}", "fontSize": "{primitive.font.size.body}" } },
      "body-sm": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.normal}", "fontSize": "{primitive.font.size.sm}" } },
      "label": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.semibold}", "fontSize": "{primitive.font.size.caption}" } },
      "section-label": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.sans}", "fontWeight": "{primitive.font.weight.bold}", "fontSize": "{primitive.font.size.micro}", "letterSpacing": "0.05em", "textTransform": "uppercase" }, "$description": "the uppercase card-section headers" },
      "stat": { "$type": "typography", "$value": { "fontFamily": "{primitive.font.family.display}", "fontWeight": "{primitive.font.weight.extrabold}", "fontSize": "{primitive.font.size.title}" }, "$description": "big numbers (iLvl, %)" }
    }
  },

  "component": {
    "$description": "Tier 3 — per-component tokens. Reference the semantic tier only. A component never reaches past this to a primitive.",

    "button": {
      "primary": {
        "bg": { "$type": "color", "$value": "{semantic.color.accent.default}" },
        "bg-hover": { "$type": "color", "$value": "{semantic.color.accent.hover}" },
        "text": { "$type": "color", "$value": "{semantic.color.text.on-accent}" }
      },
      "secondary": {
        "bg": { "$type": "color", "$value": "{semantic.color.surface.interactive}" },
        "text": { "$type": "color", "$value": "{semantic.color.text.primary}" },
        "border": { "$type": "color", "$value": "{semantic.color.border.default}" }
      },
      "ghost": {
        "text": { "$type": "color", "$value": "{semantic.color.text.secondary}" },
        "bg-hover": { "$type": "color", "$value": "{semantic.color.interaction.hover-overlay}" }
      },
      "danger": {
        "text": { "$type": "color", "$value": "{semantic.color.status.error}" },
        "border": { "$type": "color", "$value": "{semantic.color.status.error}" }
      },
      "radius": { "$type": "dimension", "$value": "{primitive.radius.base}" },
      "height-sm": { "$type": "dimension", "$value": "{primitive.size.control.sm}" },
      "height-base": { "$type": "dimension", "$value": "{primitive.size.control.base}" }
    },

    "card": {
      "bg": { "$type": "color", "$value": "{semantic.color.surface.card}" },
      "border": { "$type": "color", "$value": "{semantic.color.border.default}" },
      "radius": { "$type": "dimension", "$value": "{primitive.radius.lg}" },
      "padding": { "$type": "dimension", "$value": "{primitive.space.4}" },
      "gap": { "$type": "dimension", "$value": "14px" }
    },

    "tag": {
      "$description": "variant carries semantics: label (inert) | filter (aria-pressed) | nav (chevron+href). See contract.",
      "radius": { "$type": "dimension", "$value": "{primitive.radius.sm}" },
      "selected-bg-opacity": { "$type": "number", "$value": 1, "$description": "solid when selected" },
      "suggested-bg-opacity": { "$type": "number", "$value": 0.2, "$description": "20% tint when suggested/unselected" }
    },

    "gear-status-circle": {
      "$description": "target-style indicator. raid = 2-state (missing<->complete); tome = 3-state (missing->have->augmented).",
      "complete": { "$type": "color", "$value": "{semantic.color.gear-source.raid}" },
      "have": { "$type": "color", "$value": "{semantic.color.gear-source.tome}" },
      "augmented": { "$type": "color", "$value": "{semantic.color.gear-source.augmented}" },
      "missing": { "$type": "color", "$value": "{semantic.color.text.muted}" }
    },

    "toggle": {
      "$description": "recessed-orb: dark sphere in track; teal track on, dark off.",
      "track-on": { "$type": "color", "$value": "{semantic.color.accent.default}" },
      "track-off": { "$type": "color", "$value": "{semantic.color.surface.interactive}" }
    },

    "input": {
      "bg": { "$type": "color", "$value": "{semantic.color.surface.interactive}" },
      "border": { "$type": "color", "$value": "{semantic.color.border.default}" },
      "border-error": { "$type": "color", "$value": "{semantic.color.status.error}" },
      "radius": { "$type": "dimension", "$value": "{primitive.radius.base}" }
    },

    "nav": {
      "rail-width": { "$type": "dimension", "$value": "{primitive.size.rail}" },
      "spine-active-border": { "$type": "color", "$value": "{semantic.color.border.highlight}" },
      "spine-active-text": { "$type": "color", "$value": "{semantic.color.accent.default}" }
    }
  }
}
