      "membership": {
        "owner": { "$type": "color", "$value": "#0f9688" },
        "lead": { "$type": "color", "$value": "#7c3aed" },
        "member": { "$type": "color", "$value": "#2563eb" },
        "viewer": { "$type": "color", "$value": "#52525b" },
        "linked": { "$type": "color", "$value": "#b45309" }
      },
      "gear-source": {
        "raid": { "$type": "color", "$value": "#dc2626" },
        "tome": { "$type": "color", "$value": "#0f9688" },
        "base-tome": { "$type": "color", "$value": "#2563eb" },
        "augmented": { "$type": "color", "$value": "#b45309" },
        "crafted": { "$type": "color", "$value": "#ea580c" }
