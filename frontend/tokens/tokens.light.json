        "on-accent": { "$type": "color", "$value": "#ffffff" }
      },
      "border": {
        "default": { "$type": "color", "$value": "#c8c8d8" },
        "subtle": { "$type": "color", "$value": "#dcdce6" },
        "highlight": { "$type": "color", "$value": "#0f9688" },
        "focus": { "$type": "color", "$value": "rgba(15, 150, 136, 0.5)" }
      },
      "interaction": {
        "focus-ring": { "$type": "color", "$value": "rgba(15, 150, 136, 0.4)" },
        "active-bg": { "$type": "color", "$value": "rgba(15, 150, 136, 0.12)" },
        "hover-overlay": { "$type": "color", "$value": "rgba(0, 0, 0, 0.04)" }
      },
      "role": {
        "tank": { "$type": "color", "$value": "#2e7ab4" },
