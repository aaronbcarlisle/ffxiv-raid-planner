# Database URL
# SQLite (local development):
DATABASE_URL=sqlite+aiosqlite:///./data/raid_planner.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/raid_planner

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# CORS for production (comma-separated, strict whitelist)
# CORS_ORIGINS_PRODUCTION=https://xivraidplanner.app

# CORS regex pattern for Vercel preview deployments (opt-in, empty by default)
# Uncomment and set to enable preview domain access for testing PRs
# WARNING: Only use project-specific patterns, not general *.vercel.app
# CORS_VERCEL_PREVIEW_PATTERN=https://ffxiv-raid-planner-.*\.vercel\.app

# Debug mode
DEBUG=true

# Discord OAuth (get from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5174/auth/callback

# JWT Configuration
JWT_SECRET_KEY=  # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5174
